{
    "compilerOptions": {
        "target": "ES2020",
        "module": "Node16",
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "moduleResolution": "node16",
        "ignoreDeprecations": "5.0",
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "types": ["node", "express"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
